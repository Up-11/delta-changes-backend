generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum MediaType {
  IMAGE
  VIDEO
}

enum FinishingType {
  NONE       // Без отделки
  ROUGH      // Предчистовая
  CLEAN      // Чистовая
  WHITE_CUBE // Белый куб
  TURNKEY    // С ремонтом
  DESIGNER   // Дизайнерская
}

enum ApplicationStatus {
  NEW       // Новая
  IN_PROGRESS // В работе
  APPROVED  // Одобрена (квартира забронирована)
  REJECTED  // Отклонена
  COMPLETED // Завершена
  CANCELLED // Отменена
}

enum NewsStatus {
  DRAFT     // Черновик
  PUBLISHED // Опубликована
  ARCHIVED  // Архив
}

// ==================== CORE MODELS ====================

model Media {
  id          String    @id @default(uuid())
  url         String    // URL файла
  type        MediaType // IMAGE или VIDEO
  filename    String    // Имя файла
  mimeType    String    // MIME тип
  size        Int       // Размер в байтах
  altText     String?   // Alt текст для доступности
  sortOrder   Int       @default(0) @map("sort_order") // Для сортировки
  createdAt   DateTime  @default(now()) @map("created_at")

  // Связи
  bannerId    String?   @map("banner_id")
  banner      Banner?   @relation(fields: [bannerId], references: [id])

  featureId   String?   @map("feature_id")
  feature     FeatureItem? @relation(fields: [featureId], references: [id])

  galleryId   String?   @map("gallery_id")
  gallery     Gallery?  @relation(fields: [galleryId], references: [id])

  newsId      String?   @map("news_id")
  news        News?     @relation(fields: [newsId], references: [id])

  projectId   String?   @map("project_id")
  project     Project?  @relation(fields: [projectId], references: [id])

  objectBannerId String? @map("object_banner_id")
  objectBanner   Object? @relation("ObjectBanner", fields: [objectBannerId], references: [id])

  objectMasterPlanId String? @unique @map("object_master_plan_id")
  objectMasterPlan   Object? @relation("ObjectMasterPlan", fields: [objectMasterPlanId], references: [id])

  objectId String? @map("object_id")
  object   Object? @relation("ObjectMedia", fields: [objectId], references: [id])

  apartmentLayoutId String? @unique @map("apartment_layout_id")
  apartmentLayout   Apartment? @relation("ApartmentLayout", fields: [apartmentLayoutId], references: [id])

  apartmentFloorPlanId String? @unique @map("apartment_floor_plan_id")
  apartmentFloorPlan   Apartment? @relation("ApartmentFloorPlan", fields: [apartmentFloorPlanId], references: [id])

  apartmentMasterPlanId String? @unique @map("apartment_master_plan_id")
  apartmentMasterPlan   Apartment? @relation("ApartmentMasterPlan", fields: [apartmentMasterPlanId], references: [id])

  managerId   String?   @map("manager_id")
  manager     Manager?  @relation(fields: [managerId], references: [id])

  aboutPageId String?   @map("about_page_id")
  aboutPage   AboutPage? @relation(fields: [aboutPageId], references: [id])

  shareholderId String? @map("shareholder_id")
  shareholder   Shareholder? @relation(fields: [shareholderId], references: [id])

  constructionProgressId String? @map("construction_progress_id")
  constructionProgress   ConstructionProgress? @relation(fields: [constructionProgressId], references: [id])

  @@index([bannerId])
  @@index([featureId])
  @@index([galleryId])
  @@index([newsId])
  @@index([type])
  @@map("media")
}

// ==================== BANNER ====================

model Banner {
  id          String    @id @default(uuid())
  mainText    String    @map("main_text") // Главный текст
  subText     String?   @map("sub_text")  // Вспомогательный текст
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  media       Media[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("banners")
}

// ==================== PROJECT ====================

model Project {
  id          String    @id @default(uuid())
  name        String    // Название проекта
  slug        String    @unique // URL-friendly идентификатор
  description String?   // Описание проекта
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  media       Media[]
  objects     Object[]
  apartments  Apartment[]

  @@index([slug])
  @@index([isActive])
  @@index([sortOrder])
  @@map("projects")
}

// ==================== OBJECT (КОМПЛЕКС/ДОМ) ====================

model Object {
  id                  String    @id @default(uuid())
  name                String    // Название объекта
  slug                String    @unique // URL-friendly

  // Геолокация
  latitude            Float?    // Широта
  longitude           Float?    // Долгота

  // Адрес
  address             String?   // Полный адрес

  // Характеристики
  completionDate      DateTime?   @map("completion_date") // Срок сдачи
  floors              Int?      // Этажность
  finishing           FinishingType? // Тип отделки

  // Описание
  description         String?   @db.Text

  // Концепция и философия
  conceptTitle        String?   @map("concept_title")
  conceptText         String?   @map("concept_text") @db.Text

  // Публикация
  isActive            Boolean   @default(true) @map("is_active")
  sortOrder           Int       @default(0) @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Связи
  projectId           String    @map("project_id")
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  banner              Media[]   @relation("ObjectBanner") // Фото/видео баннер
  masterPlan          Media?    @relation("ObjectMasterPlan") // Генплан
  media               Media[]   @relation("ObjectMedia") // Общие фото

  features            FeatureItem[]
  galleries           Gallery[]
  apartments          Apartment[]
  constructionProgress ConstructionProgress[]
  infrastructure      InfrastructurePoint[]

  @@index([projectId])
  @@index([slug])
  @@index([isActive])
  @@index([completionDate])
  @@index([sortOrder])
  @@map("objects")
}

// ==================== CONSTRUCTION PROGRESS (ХОД СТРОИТЕЛЬСТВА) ====================

model ConstructionProgress {
  id          String    @id @default(uuid())
  month       Int       // 1-12
  year        Int       // 2024
  title       String?   // Опциональный заголовок
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  objectId    String    @map("object_id")
  object      Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)
  
  media       Media[]   // Фото/видео отчета

  @@index([objectId])
  @@index([year, month])
  @@map("construction_progress")
}

// ==================== INFRASTRUCTURE (ИНФРАСТРУКТУРА) ====================

model InfrastructurePoint {
  id          String    @id @default(uuid())
  title       String    // Название (например, Школа №1)
  category    InfrastructureCategory
  latitude    Float
  longitude   Float
  address     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  objectId    String    @map("object_id")
  object      Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@map("infrastructure_points")
}

enum InfrastructureCategory {
  EDUCATION   // Образование (Школы, сады)
  SHOPPING    // Магазины
  HEALTH      // Здравоохранение
  SPORT       // Спорт
  LEISURE     // Досуг
  TRANSPORT   // Транспорт
}

// ==================== FEATURE ITEM (ОСОБЕННОСТИ) ====================

model FeatureItem {
  id          String    @id @default(uuid())
  title       String    // Заголовок
  description String?   // Описание
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  objectId    String    @map("object_id")
  object      Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)

  media       Media[]   // Фото особенности

  @@index([objectId])
  @@index([sortOrder])
  @@map("feature_items")
}

// ==================== GALLERY ====================

model Gallery {
  id          String    @id @default(uuid())
  title       String?   // Заголовок галереи
  text        String?   // Описание/текст
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  objectId    String    @map("object_id")
  object      Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)

  photos      Media[]   // Фото галереи

  @@index([objectId])
  @@index([sortOrder])
  @@map("galleries")
}

// ==================== APARTMENT ====================

model Apartment {
  id              String    @id @default(uuid())

  // Номер квартиры
  number          String    // Номер квартиры (155)

  // Цена и площадь
  price           Decimal   @db.Decimal(15, 2) // Цена
  area            Float?    // Общая площадь (м²)
  rooms           Int?      // Количество комнат

  // Расположение в здании
  building        String?   // Дом/корпус (1)
  entrance        String?   // Подъезд (4)
  floor           Int       // Этаж (3)
  floorTotal      Int       @map("floor_total") // Всего этажей в доме (16)

  // Характеристики
  completionDate  DateTime? @map("completion_date") // Срок сдачи
  finishing       FinishingType? // Отделка

  // Статус
  isAvailable     Boolean   @default(true) @map("is_available") // В продаже
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Связи
  projectId       String    @map("project_id")
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  objectId        String    @map("object_id")
  object          Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)

  layoutPhoto     Media?    @relation("ApartmentLayout") // Планировка
  floorPlanPhoto  Media?    @relation("ApartmentFloorPlan") // План этажа
  masterPlanPhoto Media?    @relation("ApartmentMasterPlan") // Генплан

  applications    Application[]

  @@index([projectId])
  @@index([objectId])
  @@index([isAvailable])
  @@index([price])
  @@index([rooms])
  @@index([floor])
  @@index([sortOrder])
  @@map("apartments")
}

// ==================== APPLICATION (ЗАЯВКА) ====================

model Application {
  id          String    @id @default(uuid())
  name        String    // Имя
  phone       String    // Телефон
  email       String?   // Email (дополнительно)
  comment     String?   // Комментарий

  // Статус заявки
  status      ApplicationStatus @default(NEW)

  // Источник
  source      String?   // Откуда пришла заявка (сайт, реклама и т.д.)
  ipAddress   String?   @map("ip_address") // IP адрес для защиты от спама

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  apartmentId String?   @map("apartment_id")
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([apartmentId])
  @@index([createdAt])
  @@index([phone])
  @@map("applications")
}

// ==================== NEWS ====================

model News {
  id          String    @id @default(uuid())
  title       String    // Название/заголовок
  slug        String    @unique // URL-friendly
  content     String    @db.Text // Текст новости
  excerpt     String?   // Краткое описание для превью
  publishedAt DateTime? @map("published_at") // Дата публикации
  status      NewsStatus @default(DRAFT)

  // SEO
  metaTitle   String?   @map("meta_title")
  metaDesc    String?   @map("meta_description")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  media       Media[]   // Фото/видео

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@map("news")
}

// ==================== USER (АДМИН) ====================

model User {
  id          String    @id @default(uuid())
  username    String    @unique  // Логин для входа
  password    String    // Хеш пароля
  name        String?
  role        String    @default("ADMIN") // ADMIN
  isActive    Boolean   @default(true) @map("is_active")
  lastLogin   DateTime? @map("last_login")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([username])
  @@index([role])
  @@map("users")
}

// ==================== MANAGER (ОТДЕЛ ПРОДАЖ) ====================

model Manager {
  id          String    @id @default(uuid())
  name        String    // Имя
  position    String    // Должность
  phone       String?   // Телефон
  isHead      Boolean   @default(false) @map("is_head") // Руководитель
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Связи
  media       Media[]   // Фото менеджера

  @@index([isActive])
  @@index([sortOrder])
  @@map("managers")
}

// ==================== ABOUT PAGE ====================

model AboutPage {
  id           String   @id @default(uuid())
  title        String   @default("Крупнейший девелопер Красноярска")
  subtitle     String   @default("ДЕЛЬТАСТРОЙ — эксперт в области создания качественной городской среды")
  announcement String   @default("20-летний опыт работы и достижение отметки в 1 млн м² построенного комфортного жилья") @db.Text
  
  // Stats
  stat1Value   String   @default("1 млн м²")
  stat1Label   String   @default("объем сданного жилья за 20 лет")
  stat2Value   String   @default("8 побед")
  stat2Label   String   @default("в престижном российском градостроительном конкурсе новостроек ТОП-ЖК")
  stat3Value   String   @default("500 тыс. м²")
  stat3Label   String   @default("общая площадь благоустроенных территорий в реализованных сити-проектах")
  stat4Value   String   @default("500 событий в год")
  stat4Label   String   @default("количество социокультурных мероприятий, проводимых для жителей в сданных проектах")
  
  pdfUrl       String?  @map("pdf_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Связи
  media        Media[]  // Видео или фото для Hero

  @@map("about_pages")
}

model TimelineEvent {
  id          String   @id @default(uuid())
  year        String
  title       String
  description String   @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("timeline_events")
}

model Shareholder {
  id        String   @id @default(uuid())
  name      String
  position  String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Связи
  media     Media[]  // Фото

  @@index([sortOrder])
  @@map("shareholders")
}
